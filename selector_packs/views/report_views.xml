<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_presupuesto" model="ir.actions.report">
        <field name="name">Presupuesto Personalizado</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">selector_packs.report_presupuesto_template</field>
        <field name="report_file">selector_packs.report_presupuesto_template</field>
        <field name="binding_model_id" eval="False"/>
    </record>

    <template id="report_presupuesto_template">
        <t t-call="web.html_container">
            <t t-foreach="docs.sudo()" t-as="o">
                <t t-set="partner" t-value="o.partner_id.sudo()"/>
                <t t-set="lines" t-value="o.order_line.sudo()"/>

                <t t-call="web.basic_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-6">
                                <h2>PRESUPUESTO #<span t-field="o.name"/></h2>
                            </div>
                            <div class="col-6 text-right">
                                <p><strong>Fecha:</strong> <span t-field="o.date_order" t-options='{"widget": "date"}'/></p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <p t-if="o.origin"><strong>Pack:</strong> <span t-field="o.origin"/></p>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12">
                                <strong>Cliente:</strong>
                                <p t-field="partner.name"/>
                                <p t-if="partner.email" t-field="partner.email"/>
                                <p t-if="partner.phone" t-field="partner.phone"/>
                            </div>
                        </div>

                        <table class="table table-sm o_main_table mt-4">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-right">Cant.</th>
                                    <th class="text-right">Precio Ud.</th>
                                    <th class="text-right">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <t t-set="product" t-value="line.product_id.sudo()"/>
                                    <tr>
                                        <td>
                                            <span t-field="line.name"/>
                                            <t t-if="product.product_template_attribute_value_ids">
                                                <br/>
                                                <span class="text-muted">
                                                    <t t-foreach="product.product_template_attribute_value_ids.sudo()" t-as="ptav">
                                                        <span t-field="ptav.name"/><t t-if="not ptav_last">, </t>
                                                    </t>
                                                </span>
                                            </t>
                                        </td>
                                        <td class="text-right"><span t-field="line.product_uom_qty"/></td>
                                        <td class="text-right"><span t-field="line.price_unit"/></td>
                                        <td class="text-right"><span t-field="line.price_subtotal"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row justify-content-end mt-3">
                            <div class="col-4">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Total:</strong></td>
                                        <td class="text-right"><strong><span t-field="o.amount_total"/></strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
