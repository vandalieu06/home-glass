        <!-- Plato Nature -->
        <record id="plato_nature" model="product.template">
            <field name="name">Plato Ducha Nature</field>
            <field name="type">product</field>
            <field name="list_price">211.00</field>
            <field name="description">Plato de ducha modelo Nature - Precio base (medida más pequeña)</field>
            <field
                name="image_1920"
                type="base64"
                file="selector_packs/static/src/img/platos_ducha/NATURE.png"
            />
        </record>
        <record id="plato_nature_attr_color" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="plato_nature"/>
            <field name="attribute_id" ref="attr_color_plato"/>
            <field name="value_ids" eval="[(6, 0, [ref('attr_color_plato_blanco'), ref('attr_color_plato_beige'), ref('attr_color_plato_moka'), ref('attr_color_plato_gris_perla'), ref('attr_color_plato_gris'), ref('attr_color_plato_grafito')])]"/>
